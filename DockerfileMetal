FROM arm64v8/python:3.12-bookworm

WORKDIR /app

ADD . /app

RUN apt-get update && apt-get install -y build-essential cmake libomp-dev

RUN apt-get update && apt-get install -y ffmpeg

RUN CMAKE_ARGS="-DLLAMA_METAL=on" pip install llama-cpp-python

RUN pip install --no-cache-dir -r docker/requirements-mps.txt

EXPOSE 4848

CMD ["python", "index.py"]